Cell[BoxData[{
 RowBox[{
  RowBox[{"momentRatioA", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"m1A", " ", "*", " ", 
        RowBox[{"m3A", " ", "/", " ", 
         RowBox[{"m2A", "^", "2"}]}]}], ")"}], "/.", "scalingAssumption"}], 
     ",", 
     RowBox[{"Assumptions", "->", "paramAssumption"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cumulantRatioA", " ", "=", " ", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"k1A", " ", "*", " ", 
        RowBox[{"k3A", " ", "/", " ", 
         RowBox[{"k2A", "^", "2"}]}]}], ")"}], "/.", "scalingAssumption"}], 
     ",", 
     RowBox[{"Assumptions", "->", "paramAssumption"}]}], "]"}]}], 
  ";"}]}], "Input",
